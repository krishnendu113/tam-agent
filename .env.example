# ── AWS Configuration (Mumbai region) ─────────────────────────
AWS_REGION=ap-south-1

# ── Bedrock Model IDs ─────────────────────────────────────────
BEDROCK_SONNET_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_HAIKU_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# ── Store Backend ─────────────────────────────────────────────
# Storage backend: "json" (flat files, default) or "documentdb"
# Note: "mongodb" is a deprecated alias for "documentdb"
STORE_BACKEND=json

# ── DocumentDB (AWS) ──────────────────────────────────────────
# Option 1: Provide full connection string directly (takes priority)
# DOCDB_URI=mongodb://user:pass@cluster-endpoint:27017/?tls=true&tlsCAFile=./global-bundle.pem&retryWrites=false&directConnection=true

# Option 2: Provide individual credentials (composed automatically)
# URI format: mongodb://{username}:{password}@{endpoint}:27017/?tls=true&tlsCAFile={caFile}&retryWrites=false&directConnection=true
DOCDB_CLUSTER_ENDPOINT=your-cluster.cluster-xxxxxxxxx.ap-south-1.docdb.amazonaws.com
DOCDB_USERNAME=your-docdb-username
DOCDB_PASSWORD=your-docdb-password

# TLS configuration (DocumentDB requires TLS in production)
# Path to the AWS RDS CA certificate bundle
DOCDB_TLS_CA_FILE=./global-bundle.pem
# Set to "false" for local development without TLS
DOCDB_TLS_ENABLED=true

# Database name (shared across backends)
MONGODB_DB_NAME=tam-agent

# ── Infrastructure Toggle (App Runner + DocumentDB) ───────────
# Used by scripts/infra-toggle.js and POST /api/admin/infra-toggle
APPRUNNER_SERVICE_ARN=arn:aws:apprunner:ap-south-1:123456789012:service/tam-agent/xxxxxxxxxxxx
DOCDB_CLUSTER_IDENTIFIER=your-docdb-cluster-id

# ── Context Compaction ────────────────────────────────────────
# Percentage of max context window to trigger compaction (default: 75)
CONTEXT_COMPACTION_THRESHOLD=75
# Number of recent turns to preserve verbatim during compaction (default: 5)
CONTEXT_COMPACTION_PRESERVE_TURNS=5

# ── LangFuse (Observability & Tracing) ────────────────────────
# LangFuse connection (all three required for tracing; omit for no-op mode)
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Model pricing for cost attribution (USD per 1000 tokens)
HAIKU_INPUT_COST_PER_1K=0.00025
HAIKU_OUTPUT_COST_PER_1K=0.00125
SONNET_INPUT_COST_PER_1K=0.003
SONNET_OUTPUT_COST_PER_1K=0.015

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=24h

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
ALLOWED_DOMAINS=capillarytech.com

# ── Jira (Atlassian Cloud) ────────────────────────────────────
JIRA_BASE_URL=https://capillarytech.atlassian.net
JIRA_EMAIL=your-email@capillarytech.com
JIRA_API_TOKEN=your-atlassian-api-token

# ── Confluence (Atlassian Cloud — shares auth with Jira) ──────
CONFLUENCE_BASE_URL=https://capillarytech.atlassian.net/wiki
CONFLUENCE_API_TOKEN=your-atlassian-api-token

# ── Capillary Docs MCP (Kapa) ─────────────────────────────────
CAPILLARY_DOCS_MCP_URL=https://capdocumentation.mcp.kapa.ai
CAPILLARY_DOCS_MCP_TOKEN=your-mcp-bearer-token

# ── Docs Web Search (sitemap-based) ──────────────────────────
WEB_SEARCH_SITEMAP_URL=https://docs.capillarytech.com/sitemap.xml
