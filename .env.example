# AWS Configuration (Mumbai region)
AWS_REGION=ap-south-1

# Bedrock Model IDs (available via Cross-Region Inference in ap-south-1)
BEDROCK_SONNET_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_HAIKU_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# MongoDB (optional — use JSON store if not needed)
MONGODB_URI=mongodb://localhost:27017/tam-agent

# Store backend: "json" or "mongo"
STORE_BACKEND=json

# Server
PORT=3000
