# ── AWS Configuration (Mumbai region) ─────────────────────────
AWS_REGION=ap-south-1

# ── Bedrock Model IDs ─────────────────────────────────────────
BEDROCK_SONNET_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_HAIKU_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# ── Store Backend ─────────────────────────────────────────────
# Storage backend: "json" (flat files, default) or "mongodb"
STORE_BACKEND=mongodb

# ── MongoDB ───────────────────────────────────────────────────
# Option 1: Provide full connection string directly
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Option 2: Provide Atlas credentials (connection string composed automatically)
# Template: mongodb+srv://{username}:{password}@{cluster}/?retryWrites=true&w=majority&appName={appName}
MONGODB_USERNAME=your-atlas-username
MONGODB_PASSWORD=your-atlas-password
MONGODB_CLUSTER=solution-agent.ikuk2cg.mongodb.net
MONGODB_APP_NAME=solution-agent
MONGODB_DB_NAME=tam-agent

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=24h

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
ALLOWED_DOMAINS=capillarytech.com

# ── Jira (Atlassian Cloud) ────────────────────────────────────
JIRA_BASE_URL=https://capillarytech.atlassian.net
JIRA_EMAIL=your-email@capillarytech.com
JIRA_API_TOKEN=your-atlassian-api-token

# ── Confluence (Atlassian Cloud — shares auth with Jira) ──────
CONFLUENCE_BASE_URL=https://capillarytech.atlassian.net/wiki
CONFLUENCE_API_TOKEN=your-atlassian-api-token

# ── Capillary Docs MCP (Kapa) ─────────────────────────────────
CAPILLARY_DOCS_MCP_URL=https://capdocumentation.mcp.kapa.ai
CAPILLARY_DOCS_MCP_TOKEN=your-mcp-bearer-token

# ── Docs Web Search (sitemap-based) ──────────────────────────
WEB_SEARCH_SITEMAP_URL=https://docs.capillarytech.com/sitemap.xml
