# AWS Configuration (Mumbai region)
AWS_REGION=ap-south-1

# Bedrock Model IDs (available via Cross-Region Inference in ap-south-1)
BEDROCK_SONNET_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_HAIKU_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# MongoDB (optional — use JSON store if not needed)
MONGODB_URI=mongodb://localhost:27017/tam-agent

# Store backend: "json" or "mongo"
STORE_BACKEND=json

# Server
PORT=3000

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=24h

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
ALLOWED_DOMAINS=capillarytech.com

# Jira (Atlassian Cloud)
JIRA_BASE_URL=https://capillarytech.atlassian.net
JIRA_EMAIL=your-email@capillarytech.com
JIRA_API_TOKEN=your-atlassian-api-token

# Confluence (Atlassian Cloud — shares auth with Jira)
CONFLUENCE_BASE_URL=https://capillarytech.atlassian.net/wiki
CONFLUENCE_API_TOKEN=your-atlassian-api-token

# Capillary Docs MCP (Kapa)
CAPILLARY_DOCS_MCP_URL=https://your-kapa-mcp-server.example.com
CAPILLARY_DOCS_MCP_TOKEN=your-mcp-bearer-token
